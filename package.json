{
  "name": "@vyuhlabs/dxkit",
  "version": "1.6.1",
  "description": "AI-native developer experience toolkit for any repository",
  "license": "MIT",
  "author": "Vyuh Labs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vyuh-labs/dxkit.git"
  },
  "homepage": "https://github.com/vyuh-labs/dxkit#readme",
  "bugs": {
    "url": "https://github.com/vyuh-labs/dxkit/issues"
  },
  "bin": {
    "vyuh-dxkit": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "default": "./dist/lib.js"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "templates/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "build": "node scripts/copy-templates.js && tsc",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "npm run build && vitest run",
    "test:changed": "vitest run --changed",
    "test:coverage": "npm run build && vitest run --coverage",
    "test:integration": "npm run build && vitest run --config vitest.integration.config.ts",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^17.4.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.11.0",
    "vitest": "^2.1.4"
  },
  "keywords": [
    "vyuh",
    "dxkit",
    "claude",
    "copilot",
    "codex",
    "cursor",
    "dx",
    "developer-experience",
    "ai",
    "skills"
  ]
}
