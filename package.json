{
  "name": "@vyuhlabs/dxkit",
  "version": "2.21.1",
  "description": "A deterministic stop condition and code-graph context layer for AI coding agents: gives agents a code graph to make changes, then blocks only net-new detector-backed regressions at the stop boundary, with no model in the gate.",
  "license": "MIT",
  "author": "Vyuh Labs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vyuh-labs/dxkit.git"
  },
  "homepage": "https://github.com/vyuh-labs/dxkit#readme",
  "bugs": {
    "url": "https://github.com/vyuh-labs/dxkit/issues"
  },
  "bin": {
    "vyuh-dxkit": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "default": "./dist/lib.js"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "templates/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "build": "node scripts/copy-templates.js && tsc",
    "prepublishOnly": "node scripts/require-ci.js && npm run build",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "npm run build && vitest run",
    "test:changed": "vitest run --changed",
    "test:coverage": "npm run build && vitest run --coverage",
    "test:integration": "npm run build && vitest run --config vitest.integration.config.ts",
    "new-lang": "node scripts/scaffold-language.js",
    "dxkit:health": "npm run build && node dist/index.js health",
    "dxkit:guardrail": "npm run build && node dist/index.js guardrail check",
    "dxkit:baseline:refresh": "npm run build && node dist/index.js baseline create --force",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/hosted-git-info": "^3.0.5",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^17.4.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.11.0",
    "vis-network": "^9.1.13",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "ai-coding-agents",
    "agentic-development",
    "claude-code",
    "codex",
    "guardrails",
    "brownfield",
    "baseline",
    "static-analysis",
    "code-quality",
    "security-scanning",
    "pre-commit-hooks",
    "ci-cd",
    "semgrep",
    "snyk",
    "codeql",
    "sarif",
    "dxkit",
    "vyuh"
  ],
  "dependencies": {
    "exceljs": "^4.4.0",
    "hosted-git-info": "^9.0.2",
    "tree-sitter-wasms": "0.1.13",
    "web-tree-sitter": "^0.25.10"
  }
}
