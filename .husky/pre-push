# Early-exit on delete-only pushes (e.g. `git push origin --delete <branch>`).
# Git invokes pre-push with stdin lines of the form
#   <local-ref> <local-sha> <remote-ref> <remote-sha>
# For a delete, local-sha is 40 zeros and there's nothing to typecheck or
# build. Running the full gate suite against the resulting empty diff is
# wasteful AND fails ungracefully on some gates (no commits to check).
all_zero=true
while read -r _local_ref local_sha _remote_ref _remote_sha; do
  if [ "$local_sha" != "0000000000000000000000000000000000000000" ]; then
    all_zero=false
    break
  fi
done
if $all_zero; then
  echo "[pre-push] Delete-only push detected — skipping local gates."
  exit 0
fi

# Mirror the CI gates locally so `git push` fails fast on anything
# CI would also fail on, instead of finding out 40s later in the PR
# check. The set below matches `.github/workflows/ci.yml` step-for-step
# (minus the pack-dry-run smoke, which is covered by prepublishOnly
# at release time and rarely regresses between commits).
#
# Integration tests live under test/integration/ and run via
# `npm run test:integration` (or in CI) — too slow for every push.
#
# Coverage threshold reflects the full unit suite, not --changed scope,
# so the number is meaningful (a partial run would underreport).
#
# Inner-loop dev iteration: use `npm run test:changed` (vitest's
# import-graph-aware testmon-equivalent) for fast affected-only feedback.
# Push gate intentionally runs everything because (a) coverage threshold
# requires it and (b) --changed misses indirect TS-type cascades through
# the dispatcher / capability registry that the full suite catches.

# Fast static gates — fail before burning time on build/tests.
npm run typecheck
npm run typecheck:test
npx eslint . --max-warnings 0
npx prettier --check .
bash scripts/check-architecture.sh
bash scripts/check-docs-coverage.sh

# Slop check against the push target. Matches the CI step's
# DXKIT_SLOP_BASE=origin/main range-diff so no PR can surface slop
# that `git push` didn't already surface locally.
DXKIT_SLOP_BASE=origin/main bash scripts/check-slop.sh

# Build + unit tests with coverage, coverage threshold.
npm run build
npx vitest run --coverage
bash scripts/check-coverage.sh

# Dogfood: dxkit's own guardrail against this push, so a net-new finding
# (secret / code-pattern / dep-vuln / duplication / test-gap regression)
# fails the push the same way it would fail a customer's. Fast (~8s) — the
# repo pins committed-full mode in .dxkit/policy.json, so the check diffs
# HEAD against the committed .dxkit/baselines/main.json instead of
# re-gathering origin/main in a worktree (ref-based was ~3m45s and, on a
# JS repo, mis-flagged everything as net-new because the throwaway base
# worktree has no node_modules for jscpd/coverage/npm-audit). Fail-open if
# dxkit itself can't run (missing scanner toolchain on a contributor's
# machine); the dxkit-self-guardrail CI workflow is the authoritative gate.
# Set DXKIT_GUARDRAIL_PREPUSH=0 to skip locally.
if [ "${DXKIT_GUARDRAIL_PREPUSH:-1}" = "1" ]; then
  if ! node dist/index.js guardrail check; then
    status=$?
    if [ "$status" = "1" ]; then
      echo "[pre-push] dxkit guardrail blocked: net-new findings vs the baseline."
      echo "           Review above, then fix / allowlist / refresh the baseline."
      exit 1
    fi
    echo "[pre-push] dxkit guardrail could not run (tools) — skipping; CI enforces."
  fi
fi
